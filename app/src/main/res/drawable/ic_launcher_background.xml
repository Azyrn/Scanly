<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background: the brand pink, plus the scan sweep. The sweep fades out at
  both ends so a circular mask cuts it where it is already transparent.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0" android:color="#FF7EC8" />
                <item android:offset="1" android:color="#D9358F" />
            </gradient>
        </aapt:attr>
    </path>

    <path android:pathData="M8,51.5 h92 v5 h-92 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="8"
                android:startY="0"
                android:endX="100"
                android:endY="0">
                <item android:offset="0" android:color="#00FFFFFF" />
                <item android:offset="0.5" android:color="#8CFFFFFF" />
                <item android:offset="1" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
