<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Scanely" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Launch theme: shows the branded icon instantly, then hands off to Compose. -->
    <style name="Theme.Scanely.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <!-- Must be the real launcher art (mipmap), not the old placeholder vector. -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Scanely</item>
    </style>
</resources>