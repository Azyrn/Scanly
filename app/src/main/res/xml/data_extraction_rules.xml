<?xml version="1.0" encoding="utf-8"?><!--
   API keys live encrypted inside the settings DataStore, but the point of
   Keystore encryption is that the ciphertext can't be decrypted off this
   device anyway — excluding the file keeps a useless, undecryptable blob
   out of cloud backup and device transfer entirely, rather than relying on
   that alone. Only cosmetic prefs (theme, rate-limit counters) ride along
   in the same file, so nothing of value is lost by excluding it.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
